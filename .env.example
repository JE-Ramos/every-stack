# ──────────────────────────────────────────────
# Shared
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/everystack
GEMINI_API_KEY=

# ──────────────────────────────────────────────
# Object Storage (LocalStack locally, S3 in production)
# ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=everystack-uploads
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ──────────────────────────────────────────────
# Feature Flags (shared FE + BE, override per environment)
# ──────────────────────────────────────────────
FLAG_ENABLE_UPLOAD=true
FLAG_ENABLE_SEMANTIC_SEARCH=false
FLAG_ENABLE_ANALYTICS=false
FLAG_ENABLE_DEBUG_PANEL=false
FLAG_MAX_UPLOAD_SIZE_BYTES=10485760

# ──────────────────────────────────────────────
# Frontend — Branding (change these to rebrand)
# ──────────────────────────────────────────────
VITE_APP_NAME=EveryStack
VITE_APP_DESCRIPTION=Full-stack monorepo template

# ──────────────────────────────────────────────
# Frontend — API & Services (VITE_ prefix = embedded at build time, public)
# ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
