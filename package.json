{
    "name": "everystack",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.13.1",
    "scripts": {
        "dev": "nx run-many --target=dev --projects=frontend,backend --parallel",
        "dev:frontend": "nx dev frontend",
        "dev:backend": "nx dev backend",
        "build": "nx run-many --target=build --all",
        "build:frontend": "nx build frontend",
        "test": "nx run-many --target=test --all",
        "test:frontend": "vitest run --passWithNoTests",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --build",
        "generate:api": "pnpm --filter frontend generate:api",
        "size": "size-limit",
        "size:check": "size-limit --json",
        "graph": "nx graph",
        "affected:test": "nx affected --target=test",
        "affected:build": "nx affected --target=build",
        "prepare": "husky",
        "release:dry": "echo 'Releases are automated via release-please on push to main'"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@size-limit/preset-app": "^12.0.1",
        "@vitest/coverage-v8": "^4.1.4",
        "concurrently": "^9.1.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nx": "^22.6.5",
        "prettier": "^3.8.2",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "size-limit": "^12.0.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vitest": "^4.1.4"
    }
}
